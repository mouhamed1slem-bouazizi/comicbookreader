# Firebase (client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# App URL (for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin (server) — pick ONE approach on Render:
#
# Option A: full service account JSON as one line (starts with { )
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Option B: split vars (recommended)
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@....iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
#
# Also required for Options A and B:
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=comicbookreader-bcddb
#
# WRONG: putting only the private key in FIREBASE_SERVICE_ACCOUNT_JSON without FIREBASE_CLIENT_EMAIL
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Google Drive (admin + OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_REFRESH_TOKEN=
GOOGLE_USER_DRIVE_FOLDER_ID=

# Terabox (admin MVP)
TERABOX_NDUS=
TERABOX_JS_TOKEN=
TERABOX_APP_ID=250528
TERABOX_COMICS_DIR=/Comics

# Encryption key for cloud tokens (32+ chars recommended)
TOKEN_ENCRYPTION_KEY=

# Cron job auth (Vercel cron)
CRON_SECRET=
