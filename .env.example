# Firebase (client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# App URL (for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin (server) — use ONE of these options on Render:
# Option A: paste full service account JSON as one line
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: split credentials (easier on Render)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_ID=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Google Drive (admin + OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_REFRESH_TOKEN=
GOOGLE_USER_DRIVE_FOLDER_ID=

# Terabox (admin MVP)
TERABOX_NDUS=
TERABOX_JS_TOKEN=
TERABOX_APP_ID=250528
TERABOX_COMICS_DIR=/Comics

# Encryption key for cloud tokens (32+ chars recommended)
TOKEN_ENCRYPTION_KEY=

# Cron job auth (Vercel cron)
CRON_SECRET=
